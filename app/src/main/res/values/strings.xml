    <!-- Configuració -->
    <string name="settings">Configuració</string>
    <string name="settings_title">Configuració</string>
    <string name="settings_subtitle">Micròfon, moviment i càlcul del son</string>
    <string name="settings_equalization_title">Realç del volum</string>
    <string name="settings_equalization_hint">%1$d%%</string>
    <string name="settings_equalization_description">A 0%% els sons es desen amb el volum capturat. Amb valors alts, els sons fluixos es pugen abans de desar-los perquè siguin més fàcils d\'escoltar; això també pot fer que sons llunyans semblin més propers i forts.</string>
    <string name="settings_equalization_natural">Natural</string>
    <string name="settings_equalization_strong">Més igualat</string>
    <string name="settings_test_title">Prova de micròfon</string>
    <string name="settings_test_body">Grava una mostra de 5 segons amb el mateix processament que tindran les sessions noves. Fes un soroll fluix i un de fort per comparar el resultat.</string>
    <string name="settings_test_record">Grava 5 s</string>
    <string name="settings_test_recording">Gravant…</string>
    <string name="settings_test_play">Escolta la prova</string>
    <string name="settings_test_stop">Atura</string>
    <string name="settings_test_ready">Prova gravada. Escolta-la i ajusta el realç si cal.</string>
    <string name="settings_test_error">No s\'ha pogut gravar la prova. Revisa el permís del micròfon.</string>
    <string name="settings_mic_permission">Cal permís de micròfon per fer la prova.</string>
    <string name="settings_mic_permission_button">Dóna permís</string>
    <string name="settings_phase_title">Com es calculen les fases</string>
    <string name="settings_phase_intro">Son de Nit no fa diagnòstic mèdic. Divideix la sessió en blocs de 5 minuts i calcula una activitat aproximada amb sorolls agrupats, moviments de l\'acceleròmetre, diferència entre pic i ambient, durada del so, pauses i pantalla encesa.</string>
    <string name="settings_phase_deep">Bloc molt tranquil: sense sorolls significatius, pauses ni ús de pantalla. És la fase estimada amb menys activitat.</string>
    <string name="settings_phase_rem">Activitat mitjana: algun so agrupat, canvi de respiració o moviment, però no prou intens per marcar el bloc com despert.</string>
    <string name="settings_phase_light">Activitat baixa: petits sons o moviments que superen una mica el soroll ambient.</string>
    <string name="settings_phase_awake">Activitat alta: pauses, pantalla encesa, mòbil mogut o sons significatius forts o llargs. Les pauses i els moviments clars del mòbil compten com despert.</string>

